# Backend API (required for login, products, cart)
NEXT_PUBLIC_EXTERNAL_API_URL=http://localhost:5000

# Public site origin — required on production deploy for SEO (sitemap, Open Graph, canonical)
# Local dev / CI: optional; falls back to http://127.0.0.1:$PORT when unset
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (required)
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Stripe (optional, for checkout)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
